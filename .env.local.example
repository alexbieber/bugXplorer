GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name
GITHUB_TOKEN=ghp_your_token

# Optional — open | closed | all (default all, so closed reports still appear)
# GITHUB_ISSUE_STATE=open

# Optional — comma-separated; if set, only issues with at least one of these labels (case-insensitive)
# BUGFEED_REQUIRED_LABELS=bug,telegram-reported
